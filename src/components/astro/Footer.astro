---
import BracketsIcon from "@/assets/brackets.svg"
import Button from "@/components/astro/Button"
import MaxContainer from "@/components/astro/MaxContainer.astro"
import { CONTACT } from "@/constants/contact"
import { useTranslations } from "@/i18n/utils"
import GithubOutline from "@/ui/icons/GithubOutline.astro"
import LinkedinOutline from "@/ui/icons/LinkedinOutline.astro"
import { getLocaleFromPath } from "@/utils/locale.utils"
import LocaleSwitcher from "../react/LocaleSwitcher/LocaleSwitcher"

const currentLocale = getLocaleFromPath(Astro.url.pathname)
const t = useTranslations(currentLocale)
---

<footer id="footer">
	<MaxContainer>
		<div class="footer-container flex-col sm:flex-row">
			<div class="me">
				<div class="logo mx-auto! sm:mx-0 w-fit sm:w-auto">
					<BracketsIcon />
					<span>Jonathan Cervantes Alarc&oacute;n</span>
				</div>
				<div class="copy text-center">
					© 2025 Jonathan Cervantes Alarc&oacute;n. {
						t("footer.copy")
					}
				</div>
				<LocaleSwitcher
					client:load
					currentLocale={currentLocale}
					currentPath={Astro.url.pathname}
					className="mt-4 mx-auto! sm:mx-0!"
				/>
			</div>
			<div class="networks">
				<Button
					href={CONTACT.social.github}
					icon={GithubOutline}
					variant="text"
					type="secondary"
					className="p-0! w-11! h-11! aspect-square!"
				/>
				<Button
					href={CONTACT.social.linkedin}
					icon={LinkedinOutline}
					variant="text"
					type="secondary"
					className="p-0! w-11! h-11! aspect-square!"
				/>
			</div>
		</div>
	</MaxContainer>
</footer>

<style>
	#footer {
		border-top: 1px solid var(--gray-color-200);
		background-color: var(--white-color);

		.footer-container {
			display: flex;
			align-items: center;
			padding: 4rem 0rem;
			flex-wrap: wrap;
			gap: 1rem;
			justify-content: center;

			/* @media only screen and (min-width: 640px) {
				gap: 3rem;
				justify-content: space-between;
			}

			@media only screen and (min-width: 1080px) {
				padding: 4rem 0rem;
			} */
		}

		.logo {
			font-weight: 700;
			display: flex;
			align-items: center;
			gap: 0.5rem;
			justify-content: center;

			@media only screen and (min-width: 600px) {
				justify-content: initial;
			}
		}

		.copy {
			color: var(--gray-color-500);
			font-size: 0.875rem;
			text-align: center;

			@media only screen and (min-width: 600px) {
				text-align: initial;
			}
		}

		.networks {
			display: flex;
			gap: 1rem;
		}
	}
</style>
