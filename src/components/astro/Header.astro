---
import BracketsIcon from "@/assets/brackets.svg"
import MaxContainer from "@/components/astro/MaxContainer.astro"
import { LINKS } from "@/constants/header"
import Link from "./Link.astro"
---

<header id="header">
	<MaxContainer>
		<div class="header-container">
			<Link href="/" className="logo px-0! h-auto!">
				<BracketsIcon class="w-6 h-6" />
				<span class="text-[16px] font-bold">JCA</span>
			</Link>
			<div class="spacer">
				{
					LINKS.map((link) => (
						<Link className="px-0! h-auto!" href={link.href}>
							<span class="text-sm font-medium">
								{link.label}
							</span>
						</Link>
					))
				}
			</div>
		</div>
	</MaxContainer>
</header>

<style>
	#header {
		position: sticky;
		top: 0;
		background-color: var(--black-opacity-50);
		backdrop-filter: blur(30px);
		color: white;
		z-index: 10;

		.header-container {
			position: sticky;
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 1.5rem 0rem;

			@media only screen and (min-width: 1080px) {
				padding: 1.5rem 0rem;
			}

			& .logo {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				/* font-weight: 700; */
			}

			& .spacer {
				display: none;

				@media only screen and (min-width: 616px) {
					display: flex;
					gap: 2rem;
					/* font-weight: 500; */
					font-size: 14px;
				}
			}
		}
	}
</style>
